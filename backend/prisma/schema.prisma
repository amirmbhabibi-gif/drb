// =============================================================================
// DaruGard – Prisma Schema
// Phase 1: Marketplace Bounded Context
//
// Design principles:
//   - Soft-delete via deletedAt (null = active row)
//   - Audit fields (createdAt, updatedAt) on every model
//   - JSONB metadata for flexible, schema-free drug attributes
//   - All IDs are UUID v4 (generated by DB default)
//   - Snake_case column names via @map; camelCase in application layer
// =============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

/// Whether this listing represents inventory the pharmacy wants to give away
/// (OFFER), receive (NEED), or exchange bidirectionally (SWAP).
enum ListingType {
  OFFER
  NEED
  SWAP
}

/// Lifecycle state of a listing. PENDING used for moderation queue (Phase 2).
enum ListingStatus {
  ACTIVE
  PENDING
  CLOSED
}

enum UserRole {
  OWNER
  MANAGER
  STAFF
  ADMIN
}

enum UserStatus {
  PENDING_PROFILE
  PENDING_VERIFICATION
  ACTIVE
  REJECTED
  SUSPENDED
}

enum PharmacyVerificationStatus {
  PENDING
  VERIFIED
  REJECTED
}

// ─── Models ───────────────────────────────────────────────────────────────────

/// Core Phase 1 entity. Represents one side of an inventory exchange intent.
///
/// Key design decisions:
///   - rawText is the source of truth for drug description (no catalog FK)
///   - metadata (JSONB) stores expiry, condition, urgency, location, images, etc.
///   - boostScore / featuredUntil are monetization hooks; null = organic ranking
///   - pharmacyId is an opaque UUID; the Pharmacy aggregate lives in its own
///     bounded context (Phase 2). Validated at the application layer by context.
model Listing {
  id           String        @id @default(uuid()) @db.Uuid
  pharmacyId   String        @map("pharmacy_id") @db.Uuid
  type         ListingType
  rawText      String        @map("raw_text") @db.Text
  metadata     Json          @default("{}") @db.JsonB
  status       ListingStatus @default(ACTIVE)

  // ── Monetization hooks (reserved, not implemented in Phase 1) ──────────────
  // boostScore   Decimal?      @map("boost_score") @db.Decimal(5, 2)
  // featuredUntil DateTime?    @map("featured_until") @db.Timestamptz
  // subscriptionTier String?   @map("subscription_tier") @db.VarChar(50)

  // ── Audit ──────────────────────────────────────────────────────────────────
  createdAt    DateTime      @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime      @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt    DateTime?     @map("deleted_at") @db.Timestamptz

  @@index([type, status])
  @@index([pharmacyId])
  @@index([status, createdAt(sort: Desc)])
  @@index([deletedAt])
  @@map("listings")
}

/// Pharmacy organisation – owns listings and employs users.
model Pharmacy {
  id                  String                     @id @default(uuid()) @db.Uuid
  name                String                     @db.VarChar(255)
  licenseNumber       String?                    @map("license_number") @db.VarChar(100)
  verified            Boolean                    @default(false)
  verificationStatus  PharmacyVerificationStatus @default(PENDING) @map("verification_status")
  licenseDocumentPath String?                    @map("license_document_path") @db.VarChar(500)
  licenseDocumentName String?                    @map("license_document_name") @db.VarChar(255)
  licenseMimeType     String?                    @map("license_mime_type") @db.VarChar(100)
  licenseSubmittedAt  DateTime?                  @map("license_submitted_at") @db.Timestamptz
  rejectionReason     String?                    @map("rejection_reason") @db.Text
  reviewedAt          DateTime?                  @map("reviewed_at") @db.Timestamptz
  reviewedById        String?                    @map("reviewed_by_id") @db.Uuid

  createdAt           DateTime                   @default(now()) @map("created_at") @db.Timestamptz
  updatedAt           DateTime                   @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt           DateTime?                  @map("deleted_at") @db.Timestamptz

  users User[]

  @@index([verificationStatus])
  @@index([deletedAt])
  @@map("pharmacies")
}

/// Authenticated user identified by Iranian mobile number.
model User {
  id         String     @id @default(uuid()) @db.Uuid
  phone      String     @unique @db.VarChar(11)
  fullName   String?    @map("full_name") @db.VarChar(255)
  role       UserRole   @default(OWNER)
  status     UserStatus @default(PENDING_PROFILE)
  pharmacyId String?    @map("pharmacy_id") @db.Uuid
  pharmacy   Pharmacy?  @relation(fields: [pharmacyId], references: [id])

  createdAt  DateTime   @default(now()) @map("created_at") @db.Timestamptz
  updatedAt  DateTime   @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt  DateTime?  @map("deleted_at") @db.Timestamptz

  @@index([pharmacyId])
  @@index([deletedAt])
  @@map("users")
}

