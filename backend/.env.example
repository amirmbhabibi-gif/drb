# =============================================================================
# DaruGard Backend – Environment Variables
# Copy this file to .env and fill in your values before starting.
# ALL variables are required unless marked optional.
# =============================================================================

# ─── Application ─────────────────────────────────────────────────────────────
NODE_ENV=development           # development | production | test
PORT=3001
API_PREFIX=api/v1
CORS_ORIGIN=http://localhost:3000  # Frontend origin (comma-separated for multiple)

# ─── Database (PostgreSQL) ───────────────────────────────────────────────────
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL=postgresql://darugard:darugard_secret@localhost:5433/darugard?schema=public

# ─── Cache & Queues (Redis) ──────────────────────────────────────────────────
# Format: redis://:PASSWORD@HOST:PORT
REDIS_URL=redis://:redis_secret@localhost:6379

# ─── FarazSMS / IranPayamak (SMS & OTP) ──────────────────────────────────────
IRANPAYAMAK_API_KEY=your_api_key_here
IRANPAYAMAK_BASE_URL=https://api.iranpayamak.com
IRANPAYAMAK_LINE_NUMBER=50002178584000
IRANPAYAMAK_OTP_PATTERN_CODE=your_approved_pattern_code
IRANPAYAMAK_OTP_PATTERN_VAR=code
IRANPAYAMAK_OTP_PATTERN_EXPIRY_VAR=expiry
IRANPAYAMAK_NUMBER_FORMAT=english

# ─── JWT (Auth) ──────────────────────────────────────────────────────────────
JWT_ACCESS_SECRET=change_me_to_a_long_random_access_secret
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_SECRET=change_me_to_a_long_random_refresh_secret
JWT_REFRESH_EXPIRY=7d

# ─── OTP Behaviour ───────────────────────────────────────────────────────────
OTP_LENGTH=6
OTP_TTL_SECONDS=120
OTP_RESEND_COOLDOWN_SECONDS=60
OTP_MAX_ATTEMPTS=5
OTP_MAX_REQUESTS_PER_HOUR=5

# ─── Admin bootstrap ─────────────────────────────────────────────────────────
# Comma-separated Iranian mobile numbers promoted to ADMIN on OTP verify
ADMIN_PHONES=
# Comma-separated phone:staticCode pairs — no SMS OTP; verify directly with the static code
# Example: 09233283893:138421,09121234567:999999
ADMIN_STATIC_OTPS=

# Comma-separated phone:staticCode pairs for non-admin test accounts (no SMS OTP)
# Example: 09944902951:123456
TEST_STATIC_OTPS=

# ─── File uploads ────────────────────────────────────────────────────────────
UPLOAD_DIR=./uploads
LICENSE_MAX_SIZE_MB=5
LICENSE_ALLOWED_MIME=image/jpeg,image/png,application/pdf

# ─── Observability (optional in dev) ─────────────────────────────────────────
# LOG_LEVEL=info                                # error | warn | info | debug
# SENTRY_DSN=                                  # Phase 2: error tracking
